# Copy to .env and fill in. Used by docker-compose (env_file) and local runs.
# Values may contain spaces; do NOT wrap them in quotes for docker-compose.

BRING_EMAIL=bring@email.com
BRING_PASSWORD=bringpassword
BRING_LIST_NAME=Groceries
BRING_LOCALE=it-IT

GOOGLE_EMAIL=email@gmail.com
# Preferred auth. Obtain once with gpsoauth (see README). Starts with "aas_et/".
GOOGLE_MASTER_TOKEN=aas_et/your-master-token
# Fallback only; Google generally rejects this now (BadAuthentication).
GOOGLE_APP_PASSWORD=abcdefghjklmnopq
GOOGLE_SHOPPING_LIST_NAME=My Shopping List
# Optional suffix stripped from item names (see README).
GOOGLE_SHOPPING_LIST_SUFFIX_REMOVED=

DEBUG=FALSE
